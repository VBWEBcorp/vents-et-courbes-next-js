      "name": "Titre interne",
      "type": "Symbol",
      "localized": false,
      "required": true,
      "validations": [
        {
          "unique": true
        }
      ],
      "helpText": "Exemple: 'Contact Page'"
    },
    {
      "id": "heroMainTitle",
      "name": "Hero - Titre principal",
      "type": "Symbol",
      "localized": true,
      "required": true,
      "helpText": "Titre principal (ex: 'Contactez-nous')"
    },
    {
      "id": "heroDescription",
      "name": "Hero - Description",
      "type": "Text",
