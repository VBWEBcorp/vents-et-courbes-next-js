    {
      "id": "mapData",
      "name": "Plan - Données (JSON)",
      "type": "Object",
      "localized": false,
      "required": false,
      "helpText": "{'address': '33 rue Danton...', 'mapImage': 'https://...', 'mapAlt': 'Plan...', 'transportInfo': 'Métro...'}"
