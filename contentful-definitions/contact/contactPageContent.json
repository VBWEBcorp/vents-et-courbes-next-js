      "name": "Formulaire - Labels des champs (JSON)",
      "type": "Object",
      "localized": false,
      "required": false,
      "helpText": "{'nameLabel': 'Nom *', 'emailLabel': 'Email *', 'phoneLabel': 'Téléphone', 'subjectLabel': 'Sujet', 'messageLabel': 'Message', 'submitButton': 'Envoyer'}"
