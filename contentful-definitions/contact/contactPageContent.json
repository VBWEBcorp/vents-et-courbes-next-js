      "required": false,
      "helpText": "Description sous le titre (ex: 'Une question, un projet ?...')"
    },
    {
      "id": "contactInfoTitle",
      "name": "Infos Contact - Titre",
      "type": "Symbol",
      "localized": true,
      "required": false,
      "helpText": "Titre section infos contact"
    },
    {
      "id": "contactInfoData",
      "name": "Infos Contact - Données (JSON)",
      "type": "Object",
      "localized": false,
      "required": false,
      "helpText": "[{'icon': 'Mail', 'title': 'Email', 'content': 'contact@...', 'link': 'mailto:...', 'additionalInfo': '...'}]"
    },
    {
      "id": "contactFormTitle",
      "name": "Formulaire - Titre",
      "type": "Symbol",
      "localized": true,
      "required": false,
      "helpText": "Titre du formulaire de contact"
